# Copia este archivo como .env y rellena tus valores
# cp .env.example .env

# ─── Cloudflare Browser Rendering ────────────────────────────────────────────
# Dónde obtener: https://dash.cloudflare.com → tu cuenta → lado izquierdo
CF_ACCOUNT_ID=tu_account_id_aqui

# Crear en: https://dash.cloudflare.com/profile/api-tokens
# Permiso requerido: "Browser Rendering – Edit"
CF_API_TOKEN=tu_api_token_aqui
